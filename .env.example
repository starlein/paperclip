# ─── Core ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
HOST=0.0.0.0
SERVE_UI=false

# ─���─ Public URL ─────────────────────────────────────────────────────────
# Required for auth callbacks and agent API access
# PAPERCLIP_PUBLIC_URL=http://localhost:3100
# PAPERCLIP_API_URL=http://localhost:3100

# ─── Authentication ─────────────────────────────────────────────────────
# Secret for Better Auth sessions (auto-generated if not set; set in production)
# BETTER_AUTH_SECRET=
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=false
# PAPERCLIP_AUTH_BASE_URL_MODE=auto
# PAPERCLIP_AUTH_PUBLIC_BASE_URL=

# ─── Agent JWT ──────────────────────────────────────────────────────────
# Secret for signing agent API keys (auto-generated if not set)
# PAPERCLIP_AGENT_JWT_SECRET=
# PAPERCLIP_AGENT_JWT_AUDIENCE=paperclip
# PAPERCLIP_AGENT_JWT_ISSUER=paperclip
# PAPERCLIP_AGENT_JWT_TTL_SECONDS=86400

# ─── LLM API Keys ──────────────────────────────────────────────────────
# Encryption secret for stored LLM keys (warns if not set)
# LLM_KEY_ENCRYPTION_SECRET=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Storage ────────────────────────────────────────────────────────────
# Provider: "local" (default) or "s3"
# PAPERCLIP_STORAGE_PROVIDER=local
# PAPERCLIP_STORAGE_LOCAL_DIR=./data/storage
# PAPERCLIP_STORAGE_S3_BUCKET=
# PAPERCLIP_STORAGE_S3_REGION=
# PAPERCLIP_STORAGE_S3_ENDPOINT=
# PAPERCLIP_STORAGE_S3_PREFIX=
# PAPERCLIP_STORAGE_S3_FORCE_PATH_STYLE=false

# ─── Secrets Provider ──────────────────────────────────────────────────
# Provider: "local-encrypted" (default), "env", or "none"
# PAPERCLIP_SECRETS_PROVIDER=local-encrypted
# PAPERCLIP_SECRETS_MASTER_KEY=
# PAPERCLIP_SECRETS_MASTER_KEY_FILE=
# PAPERCLIP_SECRETS_STRICT_MODE=false

# ─── Database Backups ──────────────────────────────────────────────────
# PAPERCLIP_DB_BACKUP_ENABLED=false
# PAPERCLIP_DB_BACKUP_DIR=./data/backups
# PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
# PAPERCLIP_DB_BACKUP_RETENTION_DAYS=7

# ─── Deployment Mode ───────────────────────────────────────────────────
# Mode: "local" (default), "docker", "cloud"
# PAPERCLIP_DEPLOYMENT_MODE=local
# PAPERCLIP_DEPLOYMENT_EXPOSURE=local

# ─── Heartbeat Scheduler ───────────────────────────────────────────────
# HEARTBEAT_SCHEDULER_ENABLED=true
# HEARTBEAT_SCHEDULER_INTERVAL_MS=60000

# ─── Migrations ─────────────────────────────────────────────────────────
# PAPERCLIP_MIGRATION_AUTO_APPLY=true
# PAPERCLIP_MIGRATION_PROMPT=false

# ─── Instance ──────────────────────────────────────────────────────────
# PAPERCLIP_HOME=~/.paperclip
# PAPERCLIP_INSTANCE_ID=
# PAPERCLIP_CONFIG=

# ─── Sandboxes ─────────────────────────────────────────────────────────
# DOCKER_HOST=
# E2B_API_KEY=

# ─── Cloud Providers (for cloud deployments) ───────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_CLOUD_PROJECT=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=

# ─── Logging ───────────────────────────────────────────────────────────
# PAPERCLIP_LOG_DIR=./data/logs
# RUN_LOG_BASE_PATH=
# WORKSPACE_OPERATION_LOG_BASE_PATH=

# ─── Attachments ───────────────────────────────────────────────────────
# PAPERCLIP_ALLOWED_ATTACHMENT_TYPES=image/png,image/jpeg,image/gif,application/pdf
# PAPERCLIP_ATTACHMENT_MAX_BYTES=10485760

# ─── Telemetry & Feedback ──────────────────────────────────────────────
# PAPERCLIP_TELEMETRY_BACKEND_URL=
# PAPERCLIP_TELEMETRY_BACKEND_TOKEN=
# PAPERCLIP_FEEDBACK_EXPORT_BACKEND_URL=
# PAPERCLIP_FEEDBACK_EXPORT_BACKEND_TOKEN=

# ─── Misc ──────────────────────────────────────────────────────────────
# PAPERCLIP_ENABLE_COMPANY_DELETION=false
# PAPERCLIP_ALLOWED_HOSTNAMES=
# PAPERCLIP_EMBEDDED_POSTGRES_VERBOSE=false
# PAPERCLIP_OPEN_ON_LISTEN=true
# PAPERCLIP_UI_DEV_MIDDLEWARE=false

# ─── UI (Vite) ─────────────────────────────────────────────────────────
# VITE_FEEDBACK_TERMS_URL=https://www.linkedin.com/groups/18235015/
# VITE_ADAPTERS=
