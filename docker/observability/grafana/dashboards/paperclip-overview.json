{
  "title": "Paperclip — Agent Platform Overview",
  "uid": "paperclip-overview",
  "tags": ["paperclip"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "agent_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(paperclip_heartbeat_runs_total, agent_id)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "skill_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(paperclip_skill_invocations_total, skill_name)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Heartbeat Runs (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (agent_id, status) (rate(paperclip_heartbeat_runs_total{agent_id=~\"$agent_id\"}[5m]) * 60)",
          "legendFormat": "{{agent_id}} / {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Heartbeat Run Duration (p50/p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, agent_id) (rate(paperclip_heartbeat_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p50 {{agent_id}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, agent_id) (rate(paperclip_heartbeat_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p95 {{agent_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Token Usage (per run, by model)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model, token_type) (rate(paperclip_tokens_used_total{agent_id=~\"$agent_id\"}[5m]) * 60)",
          "legendFormat": "{{model}} / {{token_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 4,
      "title": "API Request Latency p95",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(paperclip_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(paperclip_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(paperclip_http_requests_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Active / Stalled Runs",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "paperclip_heartbeat_runs_active",
          "legendFormat": "Active"
        },
        {
          "expr": "paperclip_heartbeat_runs_stalled",
          "legendFormat": "Stalled (>15m)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Active" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
            ]
          }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 8,
      "title": "Skill Invocations (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (skill_name, status) (rate(paperclip_skill_invocations_total{agent_id=~\"$agent_id\", skill_name=~\"$skill_name\"}[5m]) * 60)",
          "legendFormat": "{{skill_name}} / {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 9,
      "title": "Skill Success Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (skill_name) (rate(paperclip_skill_invocations_total{agent_id=~\"$agent_id\", skill_name=~\"$skill_name\", status=\"success\"}[5m])) / sum by (skill_name) (rate(paperclip_skill_invocations_total{agent_id=~\"$agent_id\", skill_name=~\"$skill_name\"}[5m])) * 100",
          "legendFormat": "{{skill_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Skill Token Usage (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (skill_name) (rate(paperclip_skill_tokens_total{skill_name=~\"$skill_name\"}[5m]) * 60)",
          "legendFormat": "{{skill_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 11,
      "title": "Skill Invocation Duration (p50/p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, skill_name) (rate(paperclip_skill_invocation_duration_seconds_bucket{agent_id=~\"$agent_id\", skill_name=~\"$skill_name\"}[5m])))",
          "legendFormat": "p50 {{skill_name}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, skill_name) (rate(paperclip_skill_invocation_duration_seconds_bucket{agent_id=~\"$agent_id\", skill_name=~\"$skill_name\"}[5m])))",
          "legendFormat": "p95 {{skill_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 12,
      "title": "Skill Invocations by Version",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (skill_name, version) (rate(paperclip_skill_invocations_total{agent_id=~\"$agent_id\", skill_name=~\"$skill_name\"}[5m]) * 60)",
          "legendFormat": "{{skill_name}} v{{version}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 7,
      "title": "Agent Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 48, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=\"paperclip-server\"} | json",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
